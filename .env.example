# Ollama (server-side; Next.js API routes call this host from your machine)
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
# Context size for /api/chat. Default 4096 in Ollama truncates long generate-plan prompts (~5k+ tokens) — use 8192+.
OLLAMA_NUM_CTX=8192

# Mapbox (browser; optional — map shows setup instructions without it)
# https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Maps: one key can cover server + browser if you enable all used APIs on it.
# Required APIs: Places (Nearby, Details, Autocomplete, Photos), Geocoding, Distance Matrix (server) + Maps JavaScript API (browser).
# Restrict by HTTP referrer for browser use; restrict by IP or none for local dev.
# https://console.cloud.google.com/google/maps-apis
GOOGLE_PLACES_API_KEY=

# Optional: set explicitly for the client bundle (same value as GOOGLE_PLACES_API_KEY is fine).
# If omitted, the app loads the key from /api/maps-key (uses GOOGLE_PLACES_API_KEY).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
